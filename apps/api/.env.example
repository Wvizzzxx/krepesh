# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/krepesh

# JWT
# IMPORTANT: Change this to a strong random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-secret-key

# CORS
# Set to your frontend URL in production, e.g. http://localhost:3000
CORS_ORIGIN=true

# PORT CONFIGURATION
# API Server: 3001
# Admin Panel: 3002
# Web Frontend: 3000
# DO NOT change these ports unless you update all frontend proxy configs!
